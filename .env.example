# Database
DATABASE_URL="file:./data/bridgeport.db"

# Encryption master key (32 bytes, base64 encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY="your-base64-encoded-32-byte-key"

# JWT secret (for auth tokens)
JWT_SECRET="your-jwt-secret-here"

# Server settings
HOST="0.0.0.0"
PORT="3000"

# DigitalOcean Container Registry
DO_REGISTRY_TOKEN="dop_v1_..."

# SSH Configuration
# SSH keys are configured per-environment via the BridgePort UI (Settings > SSH)
# Each environment has its own SSH key for security isolation
# Keys are encrypted and stored in the database
#
# Legacy fallback (optional - only used if per-environment key not configured):
# SSH_KEY_PATH="/root/.ssh/bios-infra"
# SSH_USER="root"

# Upload directory for config files
UPLOAD_DIR="./uploads"

# Initial admin user (created on first boot if no users exist)
# ADMIN_EMAIL="admin@example.com"
# ADMIN_PASSWORD="your-secure-password"

# Scheduler settings (all intervals in seconds)
SCHEDULER_ENABLED="true"
SCHEDULER_SERVER_HEALTH_INTERVAL="60"    # 1 minute
SCHEDULER_SERVICE_HEALTH_INTERVAL="60"   # 1 minute
SCHEDULER_DISCOVERY_INTERVAL="300"       # 5 minutes
SCHEDULER_UPDATE_CHECK_INTERVAL="1800"   # 30 minutes
SCHEDULER_METRICS_INTERVAL="300"         # 5 minutes - SSH metrics collection for servers with metricsMode=ssh
SCHEDULER_BACKUP_CHECK_INTERVAL="60"     # 1 minute - Check for scheduled database backups

# Agent callback URL (required for agent auto-deployment)
# This is the internal/VPC URL that monitored servers use to reach BridgePort
# Example: If BridgePort is at 10.30.10.5 in the management VPC
AGENT_CALLBACK_URL="http://10.30.10.5:3000"
