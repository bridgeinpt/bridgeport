# =============================================================================
# BridgePort Configuration
# =============================================================================
# Copy to .env and fill in values: cp .env.example .env
# Generate secrets with: openssl rand -base64 32

# =============================================================================
# REQUIRED - Core Settings
# =============================================================================

# Database (SQLite for single-instance deployments)
DATABASE_URL="file:./data/bridgeport.db"

# Encryption master key (32 bytes, base64 encoded)
# CRITICAL: Back this up! Required to decrypt secrets in the database.
# Generate with: openssl rand -base64 32
MASTER_KEY="your-base64-encoded-32-byte-key"

# JWT secret (for auth tokens)
# Generate with: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-here"

# =============================================================================
# OPTIONAL - Server Settings
# =============================================================================

# Server bind address and port
HOST="0.0.0.0"
PORT="3000"

# Upload directory for config files
UPLOAD_DIR="./uploads"

# =============================================================================
# OPTIONAL - Initial Admin User
# =============================================================================

# Created on first boot if no users exist
# ADMIN_EMAIL="admin@example.com"
# ADMIN_PASSWORD="your-secure-password"


# =============================================================================
# OPTIONAL - Scheduler Settings
# =============================================================================

# All intervals in seconds
SCHEDULER_ENABLED="true"
SCHEDULER_SERVER_HEALTH_INTERVAL="60"    # 1 minute
SCHEDULER_SERVICE_HEALTH_INTERVAL="60"   # 1 minute
SCHEDULER_DISCOVERY_INTERVAL="300"       # 5 minutes
SCHEDULER_UPDATE_CHECK_INTERVAL="1800"   # 30 minutes
SCHEDULER_METRICS_INTERVAL="300"         # 5 minutes - SSH metrics collection
SCHEDULER_BACKUP_CHECK_INTERVAL="60"     # 1 minute - Check for scheduled backups

# =============================================================================
# OPTIONAL - Agent Configuration
# =============================================================================

# Agent callback URL (required for agent auto-deployment)
# This is the internal/VPC URL that monitored servers use to reach BridgePort
# Example: If BridgePort is at 10.30.10.5 in the management VPC
# AGENT_CALLBACK_URL="http://10.30.10.5:3000"

# =============================================================================
# OPTIONAL - Webhook Configuration
# =============================================================================

# Webhook secret for CI/CD deployments
# Generate with: openssl rand -base64 32
# WEBHOOK_SECRET="your-webhook-secret"

# =============================================================================
# OPTIONAL - Sentry Error Monitoring
# =============================================================================

# Separate Sentry DSNs for backend (Node.js) and frontend (React)
# Get DSNs from your Sentry projects at https://sentry.io
# SENTRY_BACKEND_DSN="https://key@o12345.ingest.sentry.io/12345"
# SENTRY_FRONTEND_DSN="https://key@o12345.ingest.sentry.io/67890"

# Environment tag in Sentry (defaults to NODE_ENV if not set)
# SENTRY_ENVIRONMENT="production"

# Performance tracing sample rate (0.0 to 1.0, default: 0 = disabled)
# SENTRY_TRACES_SAMPLE_RATE="0"

# Kill switch to disable Sentry even when DSNs are set (default: true)
# SENTRY_ENABLED="true"
