# =============================================================================
# BRIDGEPORT Configuration
# =============================================================================
# Copy to .env and fill in values: cp .env.example .env
# Generate secrets with: openssl rand -base64 32

# =============================================================================
# REQUIRED - Core Settings
# =============================================================================

# Database (SQLite for single-instance deployments)
DATABASE_URL="file:./data/bridgeport.db"

# Encryption master key (32 bytes, base64 encoded)
# CRITICAL: Back this up! Required to decrypt secrets in the database.
# Generate with: openssl rand -base64 32
MASTER_KEY="your-base64-encoded-32-byte-key"

# JWT secret (for auth tokens)
# Generate with: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-here"

# =============================================================================
# OPTIONAL - Server Settings
# =============================================================================

# Server bind address and port
HOST="0.0.0.0"
PORT="3000"

# Node environment (development | production | test)
# NODE_ENV="production"

# Upload directory for config files
UPLOAD_DIR="./uploads"

# Plugin directory for service types and database types
# PLUGINS_DIR="./plugins"

# CORS origin(s) - comma-separated list or single origin
# In development mode, all origins are allowed regardless of this setting
# CORS_ORIGIN="https://deploy.example.com"

# =============================================================================
# OPTIONAL - Initial Admin User
# =============================================================================

# Created on first boot if no users exist
# ADMIN_EMAIL="admin@example.com"
# ADMIN_PASSWORD="your-secure-password"

# =============================================================================
# OPTIONAL - Legacy SSH Settings
# =============================================================================

# These are fallback settings. Prefer configuring SSH keys per-environment via the UI.
# SSH_KEY_PATH="/path/to/ssh/key"
# SSH_USER="root"

# =============================================================================
# OPTIONAL - Scheduler Settings
# =============================================================================

# All intervals in seconds
SCHEDULER_ENABLED="true"
SCHEDULER_SERVER_HEALTH_INTERVAL="60"    # 1 minute
SCHEDULER_SERVICE_HEALTH_INTERVAL="60"   # 1 minute
SCHEDULER_DISCOVERY_INTERVAL="300"       # 5 minutes
SCHEDULER_UPDATE_CHECK_INTERVAL="1800"   # 30 minutes
SCHEDULER_METRICS_INTERVAL="300"         # 5 minutes - SSH metrics collection
SCHEDULER_BACKUP_CHECK_INTERVAL="60"     # 1 minute - Check for scheduled backups

# How often to collect database monitoring metrics, in seconds
# SCHEDULER_DATABASE_METRICS_INTERVAL="60"

# Parallel SSH fan-out for health checks and metrics collection (pLimit).
# Raise it for fleets of 100+ servers; lower it on tiny/constrained hosts.
# SCHEDULER_CONCURRENCY="5"

# =============================================================================
# OPTIONAL - Security
# =============================================================================

# Per-IP API request cap per window, and the window length. The window is a
# duration string (e.g. "1 minute", "30 seconds").
# RATE_LIMIT_MAX="100"
# RATE_LIMIT_WINDOW="1 minute"

# Password hashing cost factor (clamped to 4-15). Higher is slower but stronger.
# BCRYPT_ROUNDS="12"

# JWT / session lifetime as a duration string (e.g. "7d", "24h", "30m").
# SESSION_TTL="7d"

# =============================================================================
# OPTIONAL - Performance / SQLite
# =============================================================================

# How long SQLite waits for a lock under WAL contention, in milliseconds. Kept
# short because better-sqlite3's busy-wait is synchronous (it blocks the event
# loop); longer contention is carried by the DB_RETRY_* async backoff below.
# SQLITE_BUSY_TIMEOUT_MS="1000"

# SQLite page cache size in KiB. Lower it on memory-constrained / ARM hosts.
# SQLITE_CACHE_SIZE_KB="64000"

# Transient SQLite write-lock contention retry (issue #299). When another writer
# holds the lock past busy_timeout — or a SQLITE_BUSY_SNAPSHOT fires — the
# operation is retried with jittered backoff before returning a retryable 503.
# DB_RETRY_MAX_ATTEMPTS="5"   # total attempts (1 + retries); set 1 to disable
# DB_RETRY_BASE_DELAY_MS="25" # backoff base, doubles each attempt
# DB_RETRY_MAX_DELAY_MS="500" # backoff cap per retry

# Max entries in the short-TTL response cache (per process) before the oldest
# half is evicted. Higher caches more distinct read responses.
# RESPONSE_CACHE_MAX_ENTRIES="500"

# Max stdout/stderr buffer for local command execution, in bytes (default 10MB).
# Raise it if local exec output is being truncated (min 1024).
# SSH_EXEC_MAX_BUFFER_BYTES="10485760"

# =============================================================================
# OPTIONAL - Webhook Subscription Delivery
# =============================================================================
#
# These tune the delivery sweep for webhook SUBSCRIPTIONS (the newer
# WebhookSubscription/WebhookDelivery path). They do NOT affect legacy outgoing
# webhooks (WebhookConfig), which are tuned via System Settings in the UI.

# How often the delivery sweep runs, in milliseconds.
# WEBHOOK_DELIVERY_INTERVAL_MS="3000"

# Parallel deliveries per sweep.
# WEBHOOK_DELIVERY_CONCURRENCY="10"

# Number of pending deliveries fetched per sweep.
# WEBHOOK_DELIVERY_BATCH_SIZE="50"

# Per-request HTTP timeout for an outbound delivery POST, in milliseconds.
# WEBHOOK_DELIVERY_TIMEOUT_MS="10000"

# Max delivery attempts before a delivery is marked failed (terminal).
# WEBHOOK_DELIVERY_MAX_ATTEMPTS="5"

# =============================================================================
# OPTIONAL - Database Query Executor (Postgres)
# =============================================================================

# Connection and statement timeouts for the main Postgres query path, in
# milliseconds.
# POSTGRES_CONNECTION_TIMEOUT_MS="10000"
# POSTGRES_STATEMENT_TIMEOUT_MS="30000"

# =============================================================================
# OPTIONAL - Database Query Executor (MySQL)
# =============================================================================

# Connection and statement timeouts for the MySQL query path, in milliseconds.
# MYSQL_CONNECTION_TIMEOUT_MS="10000"
# MYSQL_STATEMENT_TIMEOUT_MS="30000"

# =============================================================================
# OPTIONAL - Idempotency
# =============================================================================

# How long Idempotency-Key records are retained, in milliseconds (default 24h).
# IDEMPOTENCY_RETENTION_MS="86400000"

# When an in-progress idempotency record is considered stale, in milliseconds
# (default 5m).
# IDEMPOTENCY_STALE_INPROGRESS_MS="300000"

# =============================================================================
# OPTIONAL - MCP (Model Context Protocol) Server
# =============================================================================

# Off by default. When enabled, BRIDGEPORT exposes a curated subset of its API
# as agent tools at POST /mcp, authenticated with the same bearer tokens as the
# REST API. When disabled the route does not exist (/mcp -> 404). Tool outputs
# (especially logs) may be sent to whatever model the connecting client uses;
# secret/var VALUES are never returned. See docs/reference/mcp.md.
#
# Uncomment to enable. STRICT parse: ONLY "true" or "1" (case-insensitive) turn
# the MCP server on. Anything else — including "false", "0", "", or leaving it
# commented/unset — keeps it OFF (it's a network-exposed, default-off security
# toggle, so "false" must mean off).
# MCP_ENABLED="true"
#
# Optional: comma-separated PUBLIC Host header(s) clients use to reach /mcp
# (e.g. "mcp.example.com"). When set, the MCP transport's DNS-rebinding
# protection is enabled and limited to these hosts. OFF by default (the endpoint
# is bearer-authenticated); recommended to set it AND terminate TLS when exposing
# MCP to remote clients. NOT the bind address (that's HOST). See docs/reference/mcp.md.
# MCP_ALLOWED_HOSTS="mcp.example.com"

# Metrics retention (in days)
# METRICS_RETENTION_DAYS="7"

# =============================================================================
# OPTIONAL - Webhook Configuration
# =============================================================================

# Webhook secrets for CI/CD deployments (custom and GitHub webhooks)
# Generate with: openssl rand -base64 32
# WEBHOOK_SECRET="your-webhook-secret"
# GITHUB_WEBHOOK_SECRET="your-github-webhook-secret"

# =============================================================================
# OPTIONAL - Sentry Error Monitoring
# =============================================================================

# Separate Sentry DSNs for backend (Node.js) and frontend (React)
# Get DSNs from your Sentry projects at https://sentry.io
# SENTRY_BACKEND_DSN="https://key@o12345.ingest.sentry.io/12345"
# SENTRY_FRONTEND_DSN="https://key@o12345.ingest.sentry.io/67890"

# Environment tag in Sentry (defaults to NODE_ENV if not set)
# SENTRY_ENVIRONMENT="production"

# Performance tracing sample rate (0.0 to 1.0, default: 0 = disabled)
# SENTRY_TRACES_SAMPLE_RATE="0"

# Kill switch to disable Sentry even when DSNs are set (default: true)
# SENTRY_ENABLED="true"

# =============================================================================
# OPTIONAL - Agent / CLI Debug Access (read-only)
# =============================================================================
#
# These are NOT consumed by the BRIDGEPORT server. They let local tooling -- a
# coding agent (e.g. Claude Code), a debugging script, or ad-hoc curl -- query a
# RUNNING BRIDGEPORT instance for real data when investigating an issue.
#
# Create the token in the UI: Admin > Service Accounts > new account with the
# `viewer` role, then mint a token for it. A viewer token is read-only -- any
# mutating call is rejected with 403.
#
# Scoping notes: a viewer token can't mutate anything, and revealing secret
# values is admin-only -- so a viewer/operator token canNOT read decrypted
# secrets (the `secrets:read` string in /api/auth/me is advisory, role-derived
# metadata; the reveal endpoint itself enforces admin). The narrowing you CAN
# apply is per-environment: when minting the token, scope it to specific
# environment(s) instead of "all environments" to limit its blast radius.
#
# Treat BRIDGEPORT_TOKEN as a secret: it is gitignored via .env, never commit it,
# and rotate/revoke it from the Service Accounts page when finished.
#
# Usage:  curl -H "Authorization: Bearer $BRIDGEPORT_TOKEN" \
#              "$BRIDGEPORT_URL/api/environments"
#
# BRIDGEPORT_URL="https://deploy.example.com"
# BRIDGEPORT_TOKEN="bport_pat_..."
