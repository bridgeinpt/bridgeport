# BridgePort Docker Environment
# Copy to .env and generate secrets: cp .env.example .env
#
# Generate required secrets (run each command and paste the output):
#   openssl rand -base64 32   # for MASTER_KEY
#   openssl rand -base64 32   # for JWT_SECRET

# Required - Encryption master key (back this up!)
MASTER_KEY=

# Required - JWT secret for auth tokens
JWT_SECRET=

# Optional - Initial admin user (created on first boot if no users exist)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-secure-password

# Optional - Webhook secrets for CI/CD deployments
# WEBHOOK_SECRET=
# GITHUB_WEBHOOK_SECRET=

# Optional - CORS origin(s) for production (comma-separated)
# CORS_ORIGIN=https://deploy.example.com

# Optional - Sentry error monitoring
# SENTRY_BACKEND_DSN=https://key@o12345.ingest.sentry.io/12345
# SENTRY_FRONTEND_DSN=https://key@o12345.ingest.sentry.io/67890
# SENTRY_ENVIRONMENT=production
