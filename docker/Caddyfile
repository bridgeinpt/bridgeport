# BRIDGEPORT Caddy Configuration
#
# Replace `admin@example.com` with an email Let's Encrypt can reach, and
# replace `bridgeport.example.com` with the public hostname you point at
# this Caddy instance. Both are required for automatic HTTPS to work.
{
	# Email used by Let's Encrypt for expiry notices and ACME account recovery.
	email admin@example.com

	# Enable automatic HTTPS
	auto_https on
}

# BRIDGEPORT application
bridgeport.example.com {
	reverse_proxy bridgeport:3000

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		X-XSS-Protection "1; mode=block"
		Referrer-Policy strict-origin-when-cross-origin
	}

	# Compress responses
	encode gzip zstd

	# Logging
	log {
		output file /var/log/caddy/access.log
		format json
	}
}
