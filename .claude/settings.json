{
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(docker *)",
      "Bash(go *)",
      "Bash(make *)",
      "Bash(curl *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(*password*)",
      "Bash(*secret*)",
      "Bash(*token*)"
    ]
