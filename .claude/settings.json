{
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(docker *)",
      "Bash(go *)",
      "Bash(make *)",
      "Bash(curl *)",
      "Bash(git *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(*PASSWORD=*)",
      "Bash(*SECRET=*)",
      "Bash(*TOKEN=*)",
      "Bash(echo *password*)",
      "Bash(echo *secret*)",
      "Bash(echo *token*)"
    ]
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "frontend-design@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "github@claude-plugins-official": true
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-docs-drift.sh"
          }
        ]
      }
    ]
  }
}
