generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  role         String    @default("viewer") // "admin" | "operator" | "viewer"
  lastActiveAt DateTime? // Updated on each authenticated request
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  apiTokens               ApiToken[]
  deployments             Deployment[]
  auditLogs               AuditLog[]
  fileHistory             FileHistory[]
  databaseBackups         DatabaseBackup[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  deploymentPlans         DeploymentPlan[]
  createdServiceAccounts  ServiceAccount[]         @relation("ServiceAccountCreator")
}

// Machine identities for API access (not real humans, no login).
// Tokens minted against a service account survive admin turnover.
model ServiceAccount {
  id          String   @id @default(cuid())
  name        String   @unique // machine-readable identifier (e.g., "ci-deploy-staging")
  description String?
  role        String   @default("viewer") // "admin" | "operator" | "viewer"
  disabled    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdByUserId String?
  createdBy       User?   @relation("ServiceAccountCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  apiTokens ApiToken[]
  auditLogs AuditLog[]
}

model ApiToken {
  id          String  @id @default(cuid())
  name        String
  tokenHash   String  @unique
  tokenPrefix String? // First chars of the raw token for display (e.g., "bport_pat_a1b2")

  // Scope
  role            String                @default("viewer") // Effective cap; ≤ owner's role
  allEnvironments Boolean               @default(true)
  environments    ApiTokenEnvironment[]

  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  // Owner: exactly one of userId or serviceAccountId must be set
  userId           String?
  user             User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceAccountId String?
  serviceAccount   ServiceAccount? @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)

  auditLogs AuditLog[]
}

// Many-to-many: which environments a token is allowed to act on (when allEnvironments = false)
model ApiTokenEnvironment {
  apiTokenId    String
  apiToken      ApiToken    @relation(fields: [apiTokenId], references: [id], onDelete: Cascade)
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@id([apiTokenId, environmentId])
  @@index([environmentId])
}

model Environment {
  id            String  @id @default(cuid())
  name          String  @unique // staging, production
  sshPrivateKey String? // Encrypted SSH private key for this environment

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  servers             Server[]
  services            Service[]
  secrets             Secret[]
  vars                Var[]
  configFiles         ConfigFile[]
  auditLogs           AuditLog[]
  registryConnections RegistryConnection[]
  databases           Database[]
  notifications       Notification[]
  containerImages     ContainerImage[]
  deploymentPlans     DeploymentPlan[]
  healthCheckLogs     HealthCheckLog[]
  serviceConnections  ServiceConnection[]
  diagramLayout       DiagramLayout?
  externalEntities    ExternalEntity[]
  serverClusters      ServerCluster[]
  apiTokenScopes      ApiTokenEnvironment[]

  // Per-module settings (one row per environment, created eagerly)
  generalSettings       GeneralSettings?
  monitoringSettings    MonitoringSettings?
  operationsSettings    OperationsSettings?
  dataSettings          DataSettings?
  configurationSettings ConfigurationSettings?
  notificationSettings  NotificationSettings?
}

// ==================== Per-Environment Module Settings ====================

model GeneralSettings {
  id            String      @id @default(cuid())
  environmentId String      @unique
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  sshUser String @default("root") // SSH username
}

model MonitoringSettings {
  id            String      @id @default(cuid())
  environmentId String      @unique
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  enabled                 Boolean @default(false) // Master toggle for monitoring
  serverHealthIntervalMs  Int     @default(60000)
  serviceHealthIntervalMs Int     @default(60000)
  discoveryIntervalMs     Int     @default(300000)
  metricsIntervalMs       Int     @default(300000)
  updateCheckIntervalMs   Int     @default(1800000)
  backupCheckIntervalMs   Int     @default(60000)
  metricsRetentionDays    Int     @default(7)
  healthLogRetentionDays  Int     @default(30)
  bounceThreshold         Int     @default(3)
  bounceCooldownMs        Int     @default(900000)
  collectCpu              Boolean @default(true)
  collectMemory           Boolean @default(true)
  collectSwap             Boolean @default(true)
  collectDisk             Boolean @default(true)
  collectLoad             Boolean @default(true)
  collectFds              Boolean @default(true)
  collectTcp              Boolean @default(true)
  collectProcesses        Boolean @default(true)
  collectTcpChecks        Boolean @default(true)
  collectCertChecks       Boolean @default(true)
}

model OperationsSettings {
  id            String      @id @default(cuid())
  environmentId String      @unique
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  defaultDockerMode  String  @default("ssh") // "ssh" | "socket"
  defaultMetricsMode String  @default("disabled") // "disabled" | "ssh" | "agent"
  autoPruneImages    Boolean @default(false) // auto-prune after deploy and weekly
  pruneImagesMode    String  @default("dangling") // "dangling" | "all"
}

model DataSettings {
  id            String      @id @default(cuid())
  environmentId String      @unique
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  allowBackupDownload          Boolean @default(false)
  defaultMonitoringEnabled     Boolean @default(false)
  defaultCollectionIntervalSec Int     @default(300)
}

model ConfigurationSettings {
  id            String      @id @default(cuid())
  environmentId String      @unique
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  allowSecretReveal    Boolean @default(true)
  scanMinLength        Int     @default(6)
  scanEntropyThreshold Int     @default(25) // ×10 scale: 25 = 2.5 bits/char
}

// Per-environment notification settings. Currently used to override the global
// default Slack channel; `slackChannelId` is consulted only when no explicit
// SlackTypeRouting matches a notification.
model NotificationSettings {
  id            String      @id @default(cuid())
  environmentId String      @unique
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  slackChannelId String?
  slackChannel   SlackChannel? @relation(fields: [slackChannelId], references: [id], onDelete: SetNull)

  updatedAt DateTime @updatedAt
}

model Server {
  id            String    @id @default(cuid())
  name          String // e.g., app-api-staging
  hostname      String // e.g., 10.20.10.3
  publicIp      String? // Reserved IP if applicable
  tags          String // JSON array of tags
  status        String    @default("unknown") // healthy, unhealthy, unknown
  serverType    String    @default("remote") // "remote" | "host" - host servers connect via Docker gateway
  dockerMode    String    @default("ssh") // "ssh" | "socket" - how to connect to Docker daemon
  lastCheckedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Denormalized last health check cache (best-effort; full audit lives in HealthCheckLog).
  // Updated atomically by logHealthCheck so GET /:envId/health-status doesn't have to scan logs.
  // Named lastHealthCheck* to avoid collision with the pre-existing `lastCheckedAt`
  // (used by metrics collection) — visually near-identical, easy to confuse.
  lastHealthCheckStatus     String? // "success" | "failure" | "timeout"
  lastHealthCheckAt         DateTime?
  lastHealthCheckType       String? // "ssh" | "url" | "container_health" | "discovery"
  lastHealthCheckDurationMs Int?
  lastHealthCheckError      String?

  // Metrics collection settings
  metricsMode String  @default("disabled") // "ssh" | "agent" | "disabled"
  agentToken  String? // Token for agent authentication

  // Agent status tracking
  agentStatus          String    @default("unknown") // unknown|deploying|waiting|active|stale|offline
  lastAgentPushAt      DateTime? // When agent last pushed metrics (distinct from lastCheckedAt)
  agentVersion         String? // Agent version reported by agent
  agentStatusChangedAt DateTime? // When agent status last changed

  // Bootstrap state (one-click Docker/sysctl/agent/swap install). See docs/guides/server-bootstrap.md.
  bootstrapState     String    @default("not_bootstrapped") // not_bootstrapped|bootstrapped|error
  bootstrapDistro    String?   // Cached e.g. "ubuntu:22.04" from /etc/os-release
  dockerInstalled    Boolean   @default(false)
  dockerInstalledAt  DateTime?
  agentInstalledAt   DateTime? // When agent was installed via bootstrap (agentEnabled = source of truth for "installed")
  sysctlApplied      Boolean   @default(false)
  sysctlAppliedAt    DateTime?
  swapConfigured     Boolean   @default(false)
  swapConfiguredAt   DateTime?
  swapSizeMb         Int?      // Configured swapfile size (the file we created, not total system swap)

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  // Optional logical grouping into a cluster (HA pair, swarm/k8s nodes, regional)
  clusterId String?
  cluster   ServerCluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull)

  serviceDeployments ServiceDeployment[]
  metrics            ServerMetrics[]
  databases          Database[]
  containerSnapshot  AgentContainerSnapshot?
  processSnapshot    AgentProcessSnapshot?
  agentEvents        AgentEvent[]
  registryLogins     ServerRegistryLogin[]

  @@unique([environmentId, name])
  @@index([clusterId])
}

// Server-level metrics (CPU, memory, disk, load)
model ServerMetrics {
  id             String   @id @default(cuid())
  cpuPercent     Float?
  memoryUsedMb   Float?
  memoryTotalMb  Float?
  swapUsedMb     Float?
  swapTotalMb    Float?
  diskUsedGb     Float?
  diskTotalGb    Float?
  loadAvg1       Float?
  loadAvg5       Float?
  loadAvg15      Float?
  uptime         Int? // seconds
  openFds        Int? // open file descriptors
  maxFds         Int? // max file descriptors
  tcpEstablished Int? // TCP connections in ESTABLISHED state
  tcpListen      Int? // TCP connections in LISTEN state
  tcpTimeWait    Int? // TCP connections in TIME_WAIT state
  tcpCloseWait   Int? // TCP connections in CLOSE_WAIT state
  tcpTotal       Int? // Total TCP connections
  source         String // "ssh" | "agent"
  collectedAt    DateTime @default(now())

  serverId String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, collectedAt(sort: Desc)])
}

// Service is now a TEMPLATE: owns image, base config, dependencies.
// Per-server runtime state lives in ServiceDeployment.
model Service {
  id              String   @id @default(cuid())
  name            String // e.g., traefik, app-api
  imageTag        String   @default("latest") // Shared across all deployments (single source of truth in 2.0)
  typeTag         String? // Free-form operator-defined type label (e.g., "django", "postgres"); distinct from the plugin-provided ServiceType relation
  composeTemplate String? // Docker compose template with placeholders
  healthCheckUrl  String? // Optional URL to check for health (e.g., http://localhost:8000/health)
  baseEnv         String? // JSON object: base env vars applied to every deployment
  deployStrategy  String   @default("sequential") // "sequential" | "parallel" for multi-deployment deploys
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Per-service health check configuration for deployment orchestration
  healthWaitMs     Int @default(30000) // Wait after deploy before checking (default 30s)
  healthRetries    Int @default(3) // Number of health check attempts
  healthIntervalMs Int @default(5000) // Interval between retries (default 5s)

  // TCP port connectivity checks (agent-performed) - template-scope
  tcpChecks String? // JSON array: [{"host": "localhost", "port": 5432, "name": "postgres"}]

  // TLS certificate expiry checks (agent-performed) - template-scope
  certChecks String? // JSON array: [{"host": "example.com", "port": 443, "name": "api"}]

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  serviceDeployments ServiceDeployment[]
  deployments        Deployment[]
  files              ServiceFile[]
  databases          ServiceDatabase[]

  // Service type for predefined commands
  serviceTypeId String?
  serviceType   ServiceType? @relation(fields: [serviceTypeId], references: [id], onDelete: SetNull)

  // Link to container image (required - central entity for image management)
  containerImageId String
  containerImage   ContainerImage @relation(fields: [containerImageId], references: [id], onDelete: Restrict)

  // Dependencies
  dependencies ServiceDependency[] @relation("ServiceDependencies")
  dependents   ServiceDependency[] @relation("ServiceDependents")

  // Deployment plan steps
  deploymentSteps DeploymentPlanStep[]

  @@unique([environmentId, name])
}

// Per-server deployment of a Service template.
// Holds runtime state (container status, discovery), per-server overrides, and history-of-current state.
model ServiceDeployment {
  id            String  @id @default(cuid())
  serviceId     String
  service       Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serverId      String
  server        Server  @relation(fields: [serverId], references: [id], onDelete: Cascade)
  containerName String // Docker container name on this server
  composePath   String? // Path to docker-compose.yml on this server
  envOverrides  String? // JSON object: per-server env var overrides merged over Service.baseEnv
  exposedPorts  String? // JSON array of port mappings discovered for this deployment

  // Runtime state
  status           String    @default("unknown") // running, stopped, unhealthy, healthy, unknown (kept for backwards compatibility)
  containerStatus  String    @default("unknown") // running, stopped, exited, created, restarting, paused, dead, not_found
  healthStatus     String    @default("unknown") // healthy, unhealthy, unknown, none
  discoveryStatus  String    @default("found") // found, missing
  lastCheckedAt    DateTime?
  lastDiscoveredAt DateTime? // When the container was last seen during discovery
  lastDeployedAt   DateTime? // When this deployment was last successfully deployed

  // Denormalized last health check cache (best-effort; full audit lives in HealthCheckLog).
  // Updated atomically by logHealthCheck ONLY for resourceType='service_deployment' — container
  // checks log to HealthCheckLog but don't touch this cache (would clobber URL checks).
  // Named lastHealthCheck* to avoid collision with the pre-existing `lastCheckedAt`.
  lastHealthCheckStatus     String? // "success" | "failure" | "timeout"
  lastHealthCheckAt         DateTime?
  lastHealthCheckType       String? // "ssh" | "url" | "container_health" | "discovery"
  lastHealthCheckDurationMs Int?
  lastHealthCheckError      String?

  // Link to the currently deployed image digest (SHA) - per-deployment
  imageDigestId String?
  imageDigest   ImageDigest? @relation(fields: [imageDigestId], references: [id], onDelete: SetNull)

  // Agent-reported health check results (for services with healthCheckUrl)
  agentHealthSuccess    Boolean?
  agentHealthStatusCode Int?
  agentHealthDurationMs Int?
  agentHealthCheckedAt  DateTime?

  // Agent-reported TCP checks results
  agentTcpCheckResults String?
  agentTcpCheckedAt    DateTime?

  // Agent-reported cert checks results
  agentCertCheckResults String?
  agentCertCheckedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deployments     Deployment[]
  metrics         ServiceMetrics[]
  deploymentSteps DeploymentPlanStep[]
  serviceFiles    ServiceFile[]

  @@unique([serviceId, serverId])
  @@unique([serverId, containerName])
  @@index([serverId])
  @@index([serviceId])
}

// Container-level metrics (per service deployment)
model ServiceMetrics {
  id            String   @id @default(cuid())
  cpuPercent    Float?
  memoryUsedMb  Float?
  memoryLimitMb Float?
  networkRxMb   Float?
  networkTxMb   Float?
  blockReadMb   Float?
  blockWriteMb  Float?
  restartCount  Int?
  collectedAt   DateTime @default(now())

  serviceDeploymentId String
  serviceDeployment   ServiceDeployment @relation(fields: [serviceDeploymentId], references: [id], onDelete: Cascade)

  @@index([serviceDeploymentId, collectedAt(sort: Desc)])
}

model Deployment {
  id          String    @id @default(cuid())
  imageTag    String
  previousTag String? // Tag before this deployment (for rollback)
  status      String // pending, deploying, success, failed
  logs        String? // Deployment logs
  triggeredBy String // user email or "webhook"
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  durationMs  Int? // Deployment duration in milliseconds

  // Denormalised parent service id for historical queries (avoids 3-way join through ServiceDeployment)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // The actual per-server deployment that ran (nullable so legacy rows survive)
  serviceDeploymentId String?
  serviceDeployment   ServiceDeployment? @relation(fields: [serviceDeploymentId], references: [id], onDelete: SetNull)

  userId    String?
  user      User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  artifacts DeploymentArtifact[]

  // Link to container image history entry
  containerImageHistoryId String?
  containerImageHistory   ContainerImageHistory? @relation(fields: [containerImageHistoryId], references: [id], onDelete: SetNull)

  // Link to deployment plan step if part of orchestrated deployment
  planSteps DeploymentPlanStep[]

  @@index([serviceId, startedAt(sort: Desc)])
  @@index([serviceDeploymentId, startedAt(sort: Desc)])
}

model Secret {
  id             String   @id @default(cuid())
  key            String // e.g., DATABASE_URL, DJANGO_SECRET_KEY
  encryptedValue String // AES-256-GCM encrypted
  nonce          String // Encryption nonce (base64)
  description    String?
  neverReveal    Boolean  @default(false) // Write-only secret, cannot be revealed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@unique([environmentId, key])
}

model Var {
  id            String      @id @default(cuid())
  key           String
  value         String
  description   String?
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([environmentId, key])
}

// Tracks which config files reference each Secret key. Maintained on every
// ConfigFile content write so `GET /api/environments/:envId/secrets` can answer
// "what's using this secret?" with a join instead of a per-content regex scan.
// Rows reference the key by string (not FK to Secret.id) so a config file can
// reference a secret that doesn't exist yet (the UI shows it as a missing ref).
model SecretUsage {
  id            String     @id @default(cuid())
  environmentId String
  secretKey     String
  configFileId  String
  configFile    ConfigFile @relation(fields: [configFileId], references: [id], onDelete: Cascade)

  @@unique([environmentId, secretKey, configFileId])
  @@index([environmentId, secretKey])
}

// Mirror of `SecretUsage` for Vars — same shape, different column name.
model VarUsage {
  id            String     @id @default(cuid())
  environmentId String
  varKey        String
  configFileId  String
  configFile    ConfigFile @relation(fields: [configFileId], references: [id], onDelete: Cascade)

  @@unique([environmentId, varKey, configFileId])
  @@index([environmentId, varKey])
}

// Config files (compose files, Caddyfile, certificates, etc.)
model ConfigFile {
  id          String   @id @default(cuid())
  name        String // Display name (e.g., "gateway-compose", "cloudflare-cert")
  filename    String // Target filename on server (e.g., "docker-compose.yml", "cloudflare-origin.pem")
  content     String // File content (stored in DB for simplicity, base64-encoded for binary)
  description String?
  isBinary    Boolean  @default(false) // Whether this is a binary/asset file
  mimeType    String? // MIME type for binary files (e.g., "application/x-x509-ca-cert")
  fileSize    Int? // Size in bytes for display
  autoResync  Boolean  @default(true) // Re-sync attached services automatically when a referenced ${KEY} secret/var changes
  language    String   @default("plaintext") // Syntax-highlighting language hint (yaml, json, env, toml, ini, conf, sh, dockerfile, nginx, plaintext, ...)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  environmentId String
  environment   Environment   @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  services      ServiceFile[]
  history       FileHistory[]
  secretUsages  SecretUsage[]
  varUsages     VarUsage[]

  @@unique([environmentId, name])
}

// Links config files to services with target path on server.
// kind="base" rows (serviceDeploymentId=null) attach to the Service template and apply to every deployment.
// kind="override" rows (serviceDeploymentId set) override the base for that specific deployment.
model ServiceFile {
  id           String    @id @default(cuid())
  targetPath   String // Full path on server (e.g., /opt/caddy/docker-compose.yml)
  lastSyncedAt DateTime? // Last time this file was successfully synced to the server
  kind         String    @default("base") // "base" | "override"

  serviceId           String
  service             Service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceDeploymentId String?
  serviceDeployment   ServiceDeployment? @relation(fields: [serviceDeploymentId], references: [id], onDelete: Cascade)
  configFileId        String
  configFile          ConfigFile         @relation(fields: [configFileId], references: [id], onDelete: Cascade)

  @@unique([serviceId, configFileId, serviceDeploymentId])
  @@index([serviceDeploymentId])
}

// Generated deployment artifacts (compose files, env files)
model DeploymentArtifact {
  id        String   @id @default(cuid())
  type      String // compose, env, config
  name      String // Filename
  content   String // File content
  checksum  String // SHA-256 hash
  createdAt DateTime @default(now())

  deploymentId String
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
}

// Audit log for tracking all actions
model AuditLog {
  id           String   @id @default(cuid())
  action       String // deploy, restart, health_check, create, update, delete, access
  resourceType String // service, server, secret, environment, config_file, env_template
  resourceId   String? // ID of affected resource (nullable for deleted resources)
  resourceName String? // Human-readable name for display
  details      String? // JSON string with additional details
  success      Boolean  @default(true)
  error        String? // Error message if failed
  createdAt    DateTime @default(now())

  userId        String?
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  environmentId String?
  environment   Environment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)

  // When the actor was an API token (vs. a session). Null = session/JWT or system.
  apiTokenId       String?
  apiToken         ApiToken?       @relation(fields: [apiTokenId], references: [id], onDelete: SetNull)
  // When the actor was a service account (token's owner). Mutually informative with userId.
  serviceAccountId String?
  serviceAccount   ServiceAccount? @relation(fields: [serviceAccountId], references: [id], onDelete: SetNull)

  // Issue #130: link audit rows to a sync batch so operators can trace which
  // file syncs were part of which transactional batch. Plain String? (no
  // relation): the batch table is operational metadata and we don't want a
  // cascade from AuditLog into it.
  batchId String?

  @@index([createdAt(sort: Desc)])
  @@index([resourceType, resourceId])
  @@index([userId])
  @@index([environmentId])
  @@index([apiTokenId])
  @@index([serviceAccountId])
  @@index([environmentId, createdAt(sort: Desc)])
  @@index([resourceType, createdAt(sort: Desc)])
  @@index([batchId])
}

// Edit history for config files
model FileHistory {
  id       String   @id @default(cuid())
  content  String // Previous content
  editedAt DateTime @default(now())

  editedById String?
  editedBy   User?   @relation(fields: [editedById], references: [id], onDelete: SetNull)

  configFileId String?
  configFile   ConfigFile? @relation(fields: [configFileId], references: [id], onDelete: Cascade)

  @@index([configFileId, editedAt(sort: Desc)])
}

// Registry connection for image update checking
model RegistryConnection {
  id                     String    @id @default(cuid())
  name                   String // "DigitalOcean", "Docker Hub", etc.
  type                   String // "digitalocean", "dockerhub", "gcr", "ecr", "generic"
  registryUrl            String // API URL or registry domain
  repositoryPrefix       String? // e.g., "my-registry" for DO
  encryptedToken         String? // Encrypted API token
  tokenNonce             String?
  username               String? // For basic auth registries
  encryptedPassword      String?
  passwordNonce          String?
  isDefault              Boolean   @default(false)
  refreshIntervalMinutes Int       @default(30) // How often to check for updates
  autoLinkPattern        String? // Pattern for auto-linking services (e.g., "bios-*")
  lastRefreshAt          DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  environmentId   String
  environment     Environment           @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  containerImages ContainerImage[]
  serverLogins    ServerRegistryLogin[]

  @@unique([environmentId, name])
}

// Tracks which servers have been `docker login`-ed against which registries.
// A row is upserted after a successful login; deploys skip the login step when
// a fresh row exists (loggedInAt >= RegistryConnection.updatedAt). Rows are
// deleted when registry credentials change, forcing a re-login next deploy.
model ServerRegistryLogin {
  id                   String   @id @default(cuid())
  serverId             String
  registryConnectionId String
  loggedInAt           DateTime @default(now())

  server             Server             @relation(fields: [serverId], references: [id], onDelete: Cascade)
  registryConnection RegistryConnection @relation(fields: [registryConnectionId], references: [id], onDelete: Cascade)

  @@unique([serverId, registryConnectionId])
  @@index([registryConnectionId])
}

// Database for backup management
model Database {
  id                   String  @id @default(cuid())
  name                 String // Display name (e.g., "bios-postgres-staging")
  type                 String // "postgres" | "mysql" | "sqlite"
  host                 String? // Database host (for remote DBs)
  port                 Int? // Database port
  databaseName         String? // Actual database name
  encryptedCredentials String? // Encrypted username:password
  credentialsNonce     String?
  filePath             String? // For SQLite: path on server
  useSsl               Boolean @default(false) // Use TLS/SSL for connections

  // Backup storage configuration
  backupStorageType  String  @default("local") // "local" | "spaces"
  backupLocalPath    String? // Local path on server (e.g., /var/backups)
  backupSpacesBucket String? // Spaces bucket name
  backupSpacesPrefix String? // Key prefix (e.g., "backups/staging/")

  // Backup format options
  backupFormat           String @default("plain") // "plain" | "custom" | "tar"
  backupCompression      String @default("none") // "none" | "gzip"
  backupCompressionLevel Int    @default(6) // 1-9 for gzip

  // pg_dump options as JSON
  pgDumpOptions String? // {"noOwner":true,"clean":true,...}

  // Backup timeout (milliseconds)
  pgDumpTimeoutMs Int @default(300000) // 5 minutes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  serverId String?
  server   Server? @relation(fields: [serverId], references: [id], onDelete: SetNull)

  // Plugin-based database type
  databaseTypeId String?
  databaseType   DatabaseType? @relation(fields: [databaseTypeId], references: [id], onDelete: SetNull)

  // Monitoring configuration
  monitoringEnabled     Boolean   @default(true)
  collectionIntervalSec Int       @default(300)
  monitoringStatus      String    @default("unknown") // connected | error | unknown
  lastCollectedAt       DateTime?
  lastMonitoringError   String?

  backups  DatabaseBackup[]
  schedule BackupSchedule?
  services ServiceDatabase[]
  metrics  DatabaseMetrics[]

  @@unique([environmentId, name])
  @@index([environmentId, monitoringEnabled])
}

// Database backup record
model DatabaseBackup {
  id          String    @id @default(cuid())
  filename    String
  size        BigInt
  type        String // "manual" | "scheduled"
  status      String // "pending" | "in_progress" | "completed" | "failed"
  error       String?
  storageType String // "local" | "spaces"
  storagePath String // Local path or Spaces key
  progress    Int       @default(0) // 0-100
  duration    Int? // seconds
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  databaseId String
  database   Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  triggeredById String?
  triggeredBy   User?   @relation(fields: [triggeredById], references: [id], onDelete: SetNull)

  @@index([databaseId, createdAt(sort: Desc)])
}

// Backup schedule configuration
model BackupSchedule {
  id             String    @id @default(cuid())
  cronExpression String // e.g., "0 2 * * *" (daily 2am)
  retentionDays  Int       @default(7)
  enabled        Boolean   @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?

  databaseId String   @unique
  database   Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)
}

// Links services to databases
model ServiceDatabase {
  id               String @id @default(cuid())
  connectionEnvVar String // e.g., "DATABASE_URL"

  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  databaseId String
  database   Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@unique([serviceId, databaseId])
}

// Notification types (user and system events)
model NotificationType {
  id              String  @id @default(cuid())
  category        String // "user" | "system"
  code            String  @unique // e.g., "user.account_created", "system.backup_failed"
  name            String
  description     String?
  template        String // Message template with {{placeholders}}
  defaultChannels String  @default("[\"in_app\"]") // JSON array: ["in_app", "email", "webhook"]
  severity        String  @default("info") // "info" | "warning" | "critical"
  enabled         Boolean @default(true) // Admin can disable system notifications

  // Bounce settings (for system notifications with repeated failures)
  bounceEnabled   Boolean @default(false) // Whether this type uses bounce logic
  bounceThreshold Int     @default(3) // Consecutive failures before alerting
  bounceCooldown  Int     @default(900) // Seconds before allowing another alert (default 15 min)

  createdAt DateTime @default(now())

  notifications Notification[]
  preferences   NotificationPreference[]
  slackRoutings SlackTypeRouting[]
}

// Individual notifications sent to users
model Notification {
  id            String           @id @default(cuid())
  typeId        String
  type          NotificationType @relation(fields: [typeId], references: [id], onDelete: Cascade)
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  message       String
  data          String? // JSON context for additional data
  environmentId String?
  environment   Environment?     @relation(fields: [environmentId], references: [id], onDelete: SetNull)

  inAppReadAt   DateTime?
  emailSentAt   DateTime?
  webhookSentAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, inAppReadAt])
  @@index([environmentId])
}

// User preferences for notification types
model NotificationPreference {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  typeId         String
  type           NotificationType @relation(fields: [typeId], references: [id], onDelete: Cascade)
  inAppEnabled   Boolean          @default(true)
  emailEnabled   Boolean          @default(false)
  webhookEnabled Boolean          @default(true)
  environmentIds String? // JSON array of environment IDs, null = all environments
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([userId, typeId])
}

// SMTP configuration for email notifications
model SmtpConfig {
  id                String   @id @default(cuid())
  host              String
  port              Int      @default(587)
  secure            Boolean  @default(false)
  username          String?
  encryptedPassword String?
  passwordNonce     String?
  fromAddress       String
  fromName          String   @default("BRIDGEPORT")
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Outgoing webhook configurations
model WebhookConfig {
  id              String    @id @default(cuid())
  name            String
  url             String
  encryptedSecret String?
  secretNonce     String?
  headers         String? // JSON custom headers
  enabled         Boolean   @default(true)
  typeFilter      String? // JSON array of type codes to filter
  environmentIds  String? // JSON array of environment IDs
  lastTriggeredAt DateTime?
  successCount    Int       @default(0)
  failureCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Tracks consecutive failures for bounce logic
model BounceTracker {
  id                  String    @id @default(cuid())
  resourceType        String // "server" | "service" | "database"
  resourceId          String
  eventType           String // "health_check" | "offline" | "crash" | "backup"
  consecutiveFailures Int       @default(0)
  lastFailedAt        DateTime?
  lastSuccessAt       DateTime?
  alertSentAt         DateTime?

  @@unique([resourceType, resourceId, eventType])
}

// ==================== Deployment Orchestration ====================

// Central image management - one image can be linked to multiple services
model ContainerImage {
  id              String    @id @default(cuid())
  name            String // Display name: "BIOS Backend"
  imageName       String // Full path: registry.digitalocean.com/my-registry/my-app
  tagFilter       String    @default("latest") // Comma-separated glob patterns for tag-filtered ingestion
  lastCheckedAt   DateTime?
  updateAvailable Boolean   @default(false) // Set by update checks, cleared on deploy
  autoUpdate      Boolean   @default(false) // Applies to all linked services
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  environmentId        String
  environment          Environment         @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  registryConnectionId String?
  registryConnection   RegistryConnection? @relation(fields: [registryConnectionId], references: [id], onDelete: SetNull)

  // Currently deployed digest (set on successful deploy, cleared never)
  deployedDigestId String?
  deployedDigest   ImageDigest? @relation("DeployedDigest", fields: [deployedDigestId], references: [id], onDelete: SetNull)

  tagHistory      ContainerImageHistory[]
  services        Service[]
  deploymentPlans DeploymentPlan[]
  digests         ImageDigest[]

  @@unique([environmentId, imageName])
}

// Discovered image SHAs from registry syncs
model ImageDigest {
  id               String         @id @default(cuid())
  containerImageId String
  containerImage   ContainerImage @relation(fields: [containerImageId], references: [id], onDelete: Cascade)
  manifestDigest   String // Manifest list digest (sha256:...) — used for pulling
  configDigest     String? // Config digest (image ID) — stable across registries
  tags             String         @default("[]") // JSON array of tags pointing to this digest
  size             BigInt? // Compressed image size in bytes
  pushedAt         DateTime? // When this digest was pushed to the registry
  discoveredAt     DateTime       @default(now()) // When BRIDGEPORT first ingested this digest
  updatedAt        DateTime       @updatedAt

  serviceDeployments ServiceDeployment[]
  historyEntries     ContainerImageHistory[]
  deployedByImages   ContainerImage[]        @relation("DeployedDigest")

  @@unique([containerImageId, manifestDigest])
  @@index([containerImageId, discoveredAt(sort: Desc)])
  @@index([containerImageId, pushedAt(sort: Desc)])
}

// History of deployed tags for a container image
model ContainerImageHistory {
  id         String   @id @default(cuid())
  tag        String
  digest     String? // Denormalized for historical record
  status     String   @default("success") // "success" | "failed" | "rolled_back"
  deployedAt DateTime @default(now())
  deployedBy String? // user email, "webhook", "auto-update"

  containerImageId String
  containerImage   ContainerImage @relation(fields: [containerImageId], references: [id], onDelete: Cascade)

  // Link to specific image digest
  imageDigestId String?
  imageDigest   ImageDigest? @relation(fields: [imageDigestId], references: [id], onDelete: SetNull)

  // Link to deployments that used this history entry
  deployments Deployment[]

  @@index([containerImageId, deployedAt(sort: Desc)])
}

// Service dependencies - control deployment order
model ServiceDependency {
  id   String @id @default(cuid())
  type String // "health_before" | "deploy_after"

  dependentId String // Service that waits
  dependent   Service @relation("ServiceDependencies", fields: [dependentId], references: [id], onDelete: Cascade)
  dependsOnId String // Service that must be ready first
  dependsOn   Service @relation("ServiceDependents", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([dependentId, dependsOnId])
  @@index([dependentId])
  @@index([dependsOnId])
}

// Orchestrated deployment tracking
model DeploymentPlan {
  id          String  @id @default(cuid())
  name        String
  status      String  @default("pending") // pending|running|completed|failed|cancelled|rolled_back
  imageTag    String? // Target tag
  triggerType String // manual|webhook|auto_update
  triggeredBy String?

  // Rollback config - always rolls back ALL services on failure
  autoRollback Boolean @default(true)

  // Parallel execution - run same-level services in parallel
  parallelExecution Boolean @default(false)

  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  logs        String?

  createdAt DateTime @default(now())

  environmentId    String
  environment      Environment     @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  containerImageId String?
  containerImage   ContainerImage? @relation(fields: [containerImageId], references: [id], onDelete: SetNull)
  userId           String?
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  steps DeploymentPlanStep[]

  @@index([environmentId, createdAt(sort: Desc)])
}

// Individual steps in a deployment plan
model DeploymentPlanStep {
  id     String @id @default(cuid())
  order  Int
  status String @default("pending") // pending|running|success|failed|skipped|rolled_back
  action String // deploy|health_check|rollback

  targetTag   String?
  previousTag String? // For rollback

  healthPassed  Boolean?
  healthDetails String? // JSON

  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  logs        String?

  deploymentPlanId    String
  deploymentPlan      DeploymentPlan     @relation(fields: [deploymentPlanId], references: [id], onDelete: Cascade)
  serviceId           String?
  service             Service?           @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  serviceDeploymentId String?
  serviceDeployment   ServiceDeployment? @relation(fields: [serviceDeploymentId], references: [id], onDelete: SetNull)
  deploymentId        String?
  deployment          Deployment?        @relation(fields: [deploymentId], references: [id], onDelete: SetNull)

  @@index([deploymentPlanId, order])
}

// ==================== Global Settings ====================

// System-wide operational settings (singleton table)
model SystemSettings {
  id String @id @default("singleton")

  // SSH Timeouts (milliseconds)
  sshCommandTimeoutMs Int @default(60000)
  sshReadyTimeoutMs   Int @default(10000)

  // Webhook Settings
  webhookMaxRetries    Int    @default(3)
  webhookTimeoutMs     Int    @default(30000)
  webhookRetryDelaysMs String @default("[1000,5000,15000]") // JSON array

  // Database Backup
  pgDumpTimeoutMs Int @default(300000)

  // Limits
  maxUploadSizeMb     Int @default(50)
  activeUserWindowMin Int @default(15)
  registryMaxTags     Int @default(50)
  defaultLogLines     Int @default(50)

  // URLs
  publicUrl        String? // Public URL for links in notifications (e.g., https://bridgeport.example.com)
  agentCallbackUrl String? // Internal URL for agents to reach BRIDGEPORT (e.g., http://10.30.10.5:3000)

  // Agent Configuration
  agentStaleThresholdMs   Int @default(180000) // 3 min - mark agent as "stale"
  agentOfflineThresholdMs Int @default(300000) // 5 min - mark agent as "offline"

  // Registry Configuration
  doRegistryToken String? // DigitalOcean registry API token

  // Retention Policies
  auditLogRetentionDays        Int @default(90) // Days to keep audit logs (0 = forever)
  databaseMetricsRetentionDays Int @default(30) // Days to keep database monitoring metrics

  updatedAt DateTime @updatedAt
}

// Service Types for predefined commands (e.g., Django, Node.js)
model ServiceType {
  id           String   @id @default(cuid())
  name         String   @unique // "django", "nodejs", "generic"
  displayName  String // "Django", "Node.js", "Generic"
  isCustomized Boolean  @default(false) // true if admin edited via UI
  source       String   @default("plugin") // "plugin" | "user"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  commands ServiceTypeCommand[]
  services Service[]
}

// Database Types for plugin-based database definitions
model DatabaseType {
  id               String   @id @default(cuid())
  name             String   @unique // "postgres", "mysql", "sqlite", etc.
  displayName      String // "PostgreSQL", "MySQL", "SQLite"
  isCustomized     Boolean  @default(false)
  source           String   @default("plugin") // "plugin" | "user"
  connectionFields String // JSON string of field definitions
  backupCommand    String? // Template with {{placeholders}}
  restoreCommand   String?
  defaultPort      Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  monitoringConfig String? // JSON from plugin monitoring section

  commands  DatabaseTypeCommand[]
  databases Database[]
}

// Predefined commands for a database type
model DatabaseTypeCommand {
  id          String  @id @default(cuid())
  name        String // "shell", "vacuum"
  displayName String // "PostgreSQL Shell"
  command     String // "psql -h {{host}} -p {{port}} -U {{username}} {{databaseName}}"
  description String?
  sortOrder   Int     @default(0)

  databaseTypeId String
  databaseType   DatabaseType @relation(fields: [databaseTypeId], references: [id], onDelete: Cascade)

  @@unique([databaseTypeId, name])
}

// Predefined commands for a service type
model ServiceTypeCommand {
  id          String  @id @default(cuid())
  name        String // "shell", "migrate"
  displayName String // "Django Shell"
  command     String // "python manage.py shell"
  description String?
  sortOrder   Int     @default(0)

  serviceTypeId String
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id], onDelete: Cascade)

  @@unique([serviceTypeId, name])
}

// Global Spaces configuration (replaces per-environment Spaces config)
model SpacesConfig {
  id                 String   @id @default(cuid())
  accessKey          String
  encryptedSecretKey String
  secretKeyNonce     String
  region             String // "fra1"
  endpoint           String // "fra1.digitaloceanspaces.com"
  buckets            String? // JSON array of bucket names (for scoped keys that can't list buckets)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Environments where Spaces is enabled
  enabledEnvironments SpacesEnvironment[]
}

// Link global Spaces config to specific environments
model SpacesEnvironment {
  id      String  @id @default(cuid())
  enabled Boolean @default(true)

  spacesConfigId String
  spacesConfig   SpacesConfig @relation(fields: [spacesConfigId], references: [id], onDelete: Cascade)
  environmentId  String
  // Note: Can't add relation to Environment here without modifying Environment model
  // This will be handled in the query layer

  @@unique([spacesConfigId, environmentId])
}

// ==================== Agent Discovery Data ====================

// Agent-reported container discovery data (latest snapshot per server)
model AgentContainerSnapshot {
  id        String   @id @default(cuid())
  serverId  String   @unique // One snapshot per server
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  data      String // JSON array of ContainerInfo
  updatedAt DateTime @updatedAt
}

// Agent-reported top processes (latest snapshot per server)
model AgentProcessSnapshot {
  id        String   @id @default(cuid())
  serverId  String   @unique // One snapshot per server
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  data      String // JSON with byCpu, byMemory, stats
  updatedAt DateTime @updatedAt
}

// ==================== Slack Integration ====================

// Slack channel configuration for incoming webhooks
model SlackChannel {
  id               String    @id @default(cuid())
  name             String // Display name (e.g., "Alerts", "Deployments")
  slackChannelName String? // Actual Slack channel name (e.g., "#alerts")
  webhookUrl       String // Encrypted incoming webhook URL
  webhookUrlNonce  String?
  isDefault        Boolean   @default(false) // Fallback channel
  enabled          Boolean   @default(true)
  lastTestedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  typeRoutings         SlackTypeRouting[]
  notificationSettings NotificationSettings[]
}

// Routes notification types to Slack channels
model SlackTypeRouting {
  id             String           @id @default(cuid())
  typeId         String
  type           NotificationType @relation(fields: [typeId], references: [id], onDelete: Cascade)
  channelId      String
  channel        SlackChannel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  environmentIds String? // JSON array of environment IDs (null = all environments)

  @@unique([typeId, channelId])
}

// ==================== Health Check Logging ====================

// Logs for all health checks (server SSH, service URL, container health)
model HealthCheckLog {
  id            String      @id @default(cuid())
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  // What was checked
  resourceType String // "server" | "service" | "container"
  resourceId   String // Server or Service ID
  resourceName String // Denormalized for faster queries

  // Check details
  checkType String // "ssh" | "url" | "container_health" | "discovery"
  status    String // "success" | "failure" | "timeout"

  // Results
  durationMs   Int? // How long the check took
  httpStatus   Int? // HTTP status code for URL checks
  errorMessage String? // Error details if failed

  createdAt DateTime @default(now())

  @@index([environmentId, createdAt(sort: Desc)])
  @@index([resourceId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([resourceType, resourceId, createdAt(sort: Desc)])
}

// ==================== Agent Event History ====================

// Tracks agent lifecycle events (deploy, token regeneration, status changes)
model AgentEvent {
  id       String @id @default(cuid())
  serverId String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  eventType String // deploy_started, deploy_success, deploy_failed, token_regenerated, status_change
  status    String? // For status_change events: active, stale, offline, waiting
  message   String? // Error message or description
  details   String? // JSON blob for extra context (version, previous status, etc.)

  createdAt DateTime @default(now())

  @@index([serverId, createdAt(sort: Desc)])
}

// ==================== Database Monitoring Metrics ====================

// Time-series metrics for database monitoring
model DatabaseMetrics {
  id          String   @id @default(cuid())
  databaseId  String
  database    Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  metricsJson String // All query results as JSON blob
  collectedAt DateTime @default(now())

  @@index([databaseId, collectedAt(sort: Desc)])
}

// ==================== Service Topology ====================

// User-defined connections between services and/or databases
model ServiceConnection {
  id            String      @id @default(cuid())
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  // Source node
  sourceType   String // "service" | "database"
  sourceId     String // Service.id or Database.id
  sourceHandle String? // Optional handle id on the source node (e.g., "top", "bottom")

  // Target node
  targetType   String // "service" | "database"
  targetId     String // Service.id or Database.id
  targetHandle String? // Optional handle id on the target node

  // Connection metadata
  port      Int? // Port number (e.g., 5432, 6379)
  protocol  String? // "tcp" | "http" | "grpc" | etc.
  label     String? // Optional description (e.g., "Primary DB", "Redis cache")
  direction String  @default("none") // "forward" (source→target) | "none" (undirected)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([environmentId, sourceType, sourceId, targetType, targetId, port])
  @@index([environmentId, sourceType, sourceId])
  @@index([environmentId, targetType, targetId])
}

// Persisted node positions per environment for the topology diagram
model DiagramLayout {
  id            String      @id @default(cuid())
  environmentId String      @unique
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  positions String // JSON: { "service:<id>": {"x": 100, "y": 200, "width"?: 240, "height"?: 120}, ... }

  updatedAt DateTime @updatedAt
}

// External, non-server entities placed on the diagram (e.g. Cloudflare, "Web",
// a generic external client). Used as a source/target for ServiceConnection
// when sourceType/targetType == "external".
model ExternalEntity {
  id            String      @id @default(cuid())
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  kind    String // free-form: "cloudflare" | "web" | "client" | "cdn" | ...
  label   String // display label on the canvas
  iconKey String? // optional icon hint for the UI

  x      Float
  y      Float
  width  Float?
  height Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([environmentId])
}

// Logical grouping of multiple servers into a "cluster" container that can
// be moved as a unit and collapsed/expanded.
model ServerCluster {
  id            String      @id @default(cuid())
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  name      String
  color     String?
  collapsed Boolean @default(false)

  x      Float
  y      Float
  width  Float?
  height Float?

  servers Server[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([environmentId, name])
  @@index([environmentId])
}

// Atomic multi-resource sync batch (issue #130).
//
// A batch is an all-or-nothing wrapper around N config-file syncs in the same
// environment. Persisted before any op runs so a server crash mid-batch leaves
// a "pending" row + per-op rows for forensics.
//
// Actor fields (userId / apiTokenId / serviceAccountId) and `environmentId`
// are plain String? — no @relation — to keep the batch table independent of
// cascade rules on the parent rows. The audit-log entries written by the
// service carry the same actor + environment plus a `batchId` for tracing.
model SyncBatch {
  id                  String   @id @default(cuid())
  // "pending" | "ok" | "partial" | "rolled_back" | "failed"
  status              String
  rollbackOnFailure   Boolean  @default(true)
  // Optional caller-supplied idempotency key (HTTP header `Idempotency-Key`).
  // Combined with `idempotencyBodyHash` to detect same-key replays vs.
  // same-key-different-body conflicts.
  idempotencyKey      String?
  idempotencyBodyHash String?
  userId              String?
  apiTokenId          String?
  serviceAccountId    String?
  environmentId       String?
  createdAt           DateTime @default(now())
  completedAt         DateTime?

  operations SyncBatchOperation[]

  @@unique([idempotencyKey, idempotencyBodyHash])
  @@index([createdAt])
  @@index([environmentId])
}

// One operation row inside a SyncBatch. v1 only supports config-file-sync ops.
model SyncBatchOperation {
  id      String    @id @default(cuid())
  batchId String
  batch   SyncBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  index Int    // 0-based position in the original batch request
  type  String // "config-file-sync"
  configFileId String?

  // "pending" | "ok" | "failed" | "skipped" | "rolled_back" | "rollback_failed"
  status String

  // JSON `{code?, message}` from the failure (when status="failed" or
  // "rollback_failed"). Plain String to mirror AuditLog.details.
  error String?

  // Snapshot of ConfigFile.content captured BEFORE running this op, used to
  // restore the prior state during rollback. Nullable for ops that haven't run
  // yet (still "pending" / "skipped") or where we couldn't capture (e.g.
  // missing config file). For binary files we still snapshot the base64 blob.
  previousContent  String?
  previousIsBinary Boolean @default(false)

  // JSON of the per-target results from syncConfigFileToAttachedServices —
  // mirrors the shape returned by the existing sync routes so consumers can
  // reuse the same client code.
  results String?

  // If rollback was attempted but the restore-sync itself failed, surface why.
  rollbackError String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([batchId, index])
  @@index([configFileId])
}

