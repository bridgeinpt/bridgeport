{
  "name": "bridgeport",
  "version": "1.0.0",
  "description": "BRIDGEPORT - Dock. Run. Ship. Repeat. A lightweight, self-hosted tool to deploy, orchestrate, and monitor Docker services across all your servers - production-grade ops without Kubernetes.",
  "repository": {
    "type": "git",
    "url": "https://github.com/bridgeinpt/bridgeport.git"
  },
  "bugs": {
    "url": "https://github.com/bridgeinpt/bridgeport/issues"
  },
  "homepage": "https://github.com/bridgeinpt/bridgeport#readme",
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "openapi:dump": "tsx scripts/openapi-dump.ts",
    "openapi:check": "tsx scripts/openapi-dump.ts && git diff --exit-code openapi.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --testPathPattern='src/lib/.*\\.test\\.ts$'",
    "test:integration": "vitest run --project backend",
    "test:coverage": "vitest run --coverage",
    "test:migrations": "vitest run --config config/vitest.config.ts tests/migrations/",
    "test:tokens": "vitest run --config config/vitest.config.ts src/routes/api-tokens.test.ts src/routes/service-accounts.test.ts src/routes/auth.test.ts",
    "test:ui": "cd ui && vitest run",
    "test:ui:watch": "cd ui && vitest",
    "test:all": "vitest run && cd ui && vitest run",
    "test:stress": "tsx tests/stress/run.ts",
    "test:repro-299": "tsx tests/stress/repro-500.ts"
  },
  "keywords": [
    "deployment",
    "infrastructure",
    "docker",
    "self-hosted",
    "orchestration"
  ],
  "author": "BRIDGE IN <https://bridgein.pt>",
  "license": "Apache-2.0",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.60.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "dockerode": "^5.0.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "ioredis": "^5.11.1",
    "mysql2": "^3.22.5",
    "nodemailer": "^9.0.1",
    "p-limit": "^7.3.0",
    "pg": "^8.22.0",
    "ssh2": "^1.15.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/ssh2": "^1.15.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autocannon": "^8.0.0",
    "fast-jwt": "6.2.4",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "esbuild": "^0.28.1",
    "uuid": "^11"
  }
}
