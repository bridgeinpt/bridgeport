{
  "name": "bridgeport",
  "version": "1.0.0",
  "description": "BRIDGEPORT - Dock. Run. Ship. Repeat. A lightweight, self-hosted deployment management tool for Docker-based infrastructure.",
  "repository": {
    "type": "git",
    "url": "https://github.com/bridgeinpt/bridgeport.git"
  },
  "bugs": {
    "url": "https://github.com/bridgeinpt/bridgeport/issues"
  },
  "homepage": "https://github.com/bridgeinpt/bridgeport#readme",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --testPathPattern='src/lib/.*\\.test\\.ts$'",
    "test:integration": "vitest run --project backend",
    "test:coverage": "vitest run --coverage",
    "test:migrations": "vitest run --config config/vitest.config.ts tests/migrations/",
    "test:ui": "cd ui && vitest run",
    "test:ui:watch": "cd ui && vitest",
    "test:all": "vitest run && cd ui && vitest run"
  },
  "keywords": [
    "deployment",
    "infrastructure",
    "docker",
    "self-hosted",
    "orchestration"
  ],
  "author": "BRIDGE IN <https://bridgein.pt>",
  "license": "Apache-2.0",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.980.0",
    "@aws-sdk/s3-request-presigner": "^3.980.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "@prisma/client": "^6.0.0",
    "@sentry/node": "^10.38.0",
    "bcryptjs": "^2.4.3",
    "dockerode": "^4.0.9",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.9.2",
    "mysql2": "^3.16.3",
    "nodemailer": "^7.0.13",
    "p-limit": "^7.3.0",
    "pg": "^8.18.0",
    "ssh2": "^1.15.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/ssh2": "^1.15.0",
    "@vitest/coverage-v8": "^4.0.18",
    "pino-pretty": "^11.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  }
}
