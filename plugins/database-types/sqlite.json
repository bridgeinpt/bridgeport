{
  "$schema": "../schemas/database-type.schema.json",
  "name": "sqlite",
  "displayName": "SQLite",
  "connectionFields": [
    { "name": "filePath", "label": "File Path", "type": "text", "required": true },
    { "name": "serverId", "label": "Server", "type": "text", "required": true }
  ],
  "backupCommand": "sqlite3 \"{{filePath}}\" \".dump\" > \"{{outputFile}}\"",
  "restoreCommand": "sqlite3 \"{{filePath}}\" < \"{{inputFile}}\"",
  "commands": [
    { "name": "shell", "displayName": "SQLite Shell", "command": "sqlite3 \"{{filePath}}\"", "description": "Interactive SQLite shell", "sortOrder": 0 }
  ],
  "monitoring": {
    "connectionMode": "ssh",
    "queries": [
      {
        "name": "fileSize",
        "displayName": "File Size",
        "query": "stat -c %s \"{{filePath}}\" 2>/dev/null || stat -f %z \"{{filePath}}\"",
        "resultType": "scalar",
        "unit": "bytes"
      },
      {
        "name": "tableCount",
        "displayName": "Table Count",
        "query": "sqlite3 \"{{filePath}}\" \"SELECT count(*) FROM sqlite_master WHERE type='table' AND name NOT LIKE 'sqlite_%';\"",
        "resultType": "scalar"
      },
      {
        "name": "pageCount",
        "displayName": "Page Count",
        "query": "sqlite3 \"{{filePath}}\" \"PRAGMA page_count;\"",
        "resultType": "scalar"
      },
      {
        "name": "freelistCount",
        "displayName": "Freelist Pages",
        "query": "sqlite3 \"{{filePath}}\" \"PRAGMA freelist_count;\"",
        "resultType": "scalar"
      },
      {
        "name": "topTableSizes",
        "displayName": "Top Tables by Rows",
        "query": "sqlite3 -json \"{{filePath}}\" \"SELECT name, (SELECT count(*) FROM [\" || name || \"]) as rows FROM sqlite_master WHERE type='table' AND name NOT LIKE 'sqlite_%' ORDER BY 2 DESC LIMIT 10;\"",
        "resultType": "rows",
        "resultMapping": { "name": "name", "rows": "rows" }
      }
    ]
  }
}
