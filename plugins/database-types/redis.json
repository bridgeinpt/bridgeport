{
  "$schema": "../schemas/database-type.schema.json",
  "name": "redis",
  "displayName": "Redis",
  "defaultPort": 6379,
  "connectionFields": [
    { "name": "host", "label": "Host", "type": "text", "required": true, "default": "localhost" },
    { "name": "port", "label": "Port", "type": "number", "required": true, "default": 6379 },
    { "name": "password", "label": "Password", "type": "password" }
  ],
  "commands": [
    { "name": "cli", "displayName": "Redis CLI", "command": "redis-cli -h {{host}} -p {{port}}", "description": "Interactive Redis CLI", "sortOrder": 0 }
  ],
  "monitoring": {
    "connectionMode": "redis",
    "queries": [
      {
        "name": "usedMemory",
        "displayName": "Used Memory",
        "query": "INFO:used_memory",
        "resultType": "scalar",
        "unit": "bytes",
        "chartGroup": "memory"
      },
      {
        "name": "peakMemory",
        "displayName": "Peak Memory",
        "query": "INFO:used_memory_peak",
        "resultType": "scalar",
        "unit": "bytes",
        "chartGroup": "memory"
      },
      {
        "name": "memFragRatio",
        "displayName": "Memory Fragmentation",
        "query": "INFO:mem_fragmentation_ratio",
        "resultType": "scalar",
        "chartGroup": "memory"
      },
      {
        "name": "connectedClients",
        "displayName": "Connected Clients",
        "query": "INFO:connected_clients",
        "resultType": "scalar",
        "chartGroup": "clients"
      },
      {
        "name": "opsPerSec",
        "displayName": "Operations/sec",
        "query": "INFO:instantaneous_ops_per_sec",
        "resultType": "scalar",
        "chartGroup": "performance"
      },
      {
        "name": "hitRatio",
        "displayName": "Hit Ratio",
        "query": "COMPUTED:hit_ratio",
        "resultType": "scalar",
        "unit": "%",
        "chartGroup": "performance"
      },
      {
        "name": "evictedKeys",
        "displayName": "Evicted Keys",
        "query": "INFO:evicted_keys",
        "resultType": "scalar",
        "chartGroup": "performance"
      },
      {
        "name": "totalKeys",
        "displayName": "Total Keys",
        "query": "KEYSPACE:keys",
        "resultType": "scalar",
        "chartGroup": "overview"
      }
    ]
  }
}
