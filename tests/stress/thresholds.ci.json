{
  "$schema": "Stress thresholds tuned for GitHub-hosted ubuntu-latest runners. These are ~3-5x looser than the local thresholds in `thresholds.json` because shared CI runners are noisy: roughly 5-10x slower at peak and with wider variance. Headroom is ~1.5x the observed clean-build p99 so a 50% regression still slips through occasionally but a 2x regression fails consistently. Local dev still uses the tight `thresholds.json` so regressions show up on a dev's first run. Selected by run.ts when STRESS_CI=true.",
  "scenarios": {
    "auth-me": {
      "path": "/api/auth/me",
      "maxP99Ms": 100,
      "minRps": 100
    },
    "notifications-unread-count": {
      "path": "/api/notifications/unread-count",
      "maxP99Ms": 100,
      "minRps": 100
    },
    "environments-list": {
      "path": "/api/environments",
      "maxP99Ms": 100,
      "minRps": 100
    },
    "environment-detail": {
      "path": "/api/environments/{envId}",
      "maxP99Ms": 100,
      "minRps": 500
    },
    "servers-list": {
      "path": "/api/environments/{envId}/servers",
      "maxP99Ms": 200,
      "minRps": 100
    },
    "services-list": {
      "path": "/api/environments/{envId}/services",
      "maxP99Ms": 300,
      "minRps": 100
    },
    "service-detail": {
      "path": "/api/services/{serviceId}",
      "maxP99Ms": 200,
      "minRps": 100
    },
    "container-images-list": {
      "path": "/api/environments/{envId}/container-images",
      "maxP99Ms": 600,
      "minRps": 50
    },
    "monitoring-overview": {
      "path": "/api/environments/{envId}/monitoring/overview",
      "maxP99Ms": 150,
      "minRps": 100
    },
    "agents-status": {
      "path": "/api/environments/{envId}/agents",
      "maxP99Ms": 200,
      "minRps": 100
    },
    "health-status": {
      "path": "/api/environments/{envId}/health-status",
      "maxP99Ms": 250,
      "minRps": 100
    },
    "metrics-summary": {
      "path": "/api/environments/{envId}/metrics/summary",
      "maxP99Ms": 600,
      "minRps": 100
    },
    "server-metrics-history": {
      "path": "/api/environments/{envId}/metrics/history?hours=6",
      "maxP99Ms": 250,
      "minRps": 100
    },
    "service-metrics-history": {
      "path": "/api/environments/{envId}/services/metrics/history?hours=6",
      "maxP99Ms": 800,
      "minRps": 100
    },
    "database-metrics-history": {
      "path": "/api/environments/{envId}/databases/metrics/history?hours=6",
      "maxP99Ms": 250,
      "minRps": 100
    },
    "secrets-list": {
      "path": "/api/environments/{envId}/secrets",
      "maxP99Ms": 300,
      "minRps": 100
    },
    "vars-list": {
      "path": "/api/environments/{envId}/vars",
      "maxP99Ms": 150,
      "minRps": 200
    },
    "audit-logs": {
      "path": "/api/audit-logs?envId={envId}&limit=50",
      "maxP99Ms": 200,
      "minRps": 100
    },
    "health-logs": {
      "path": "/api/environments/{envId}/health-logs?limit=50",
      "maxP99Ms": 250,
      "minRps": 100
    },
    "databases-list": {
      "path": "/api/environments/{envId}/databases",
      "maxP99Ms": 200,
      "minRps": 100
    },
    "database-monitoring-summary": {
      "path": "/api/environments/{envId}/databases/monitoring-summary",
      "maxP99Ms": 250,
      "minRps": 100
    },
    "config-files-list": {
      "path": "/api/environments/{envId}/config-files",
      "maxP99Ms": 300,
      "minRps": 100
    },
    "config-fragments-list": {
      "path": "/api/environments/{envId}/config-fragments",
      "maxP99Ms": 150,
      "minRps": 200
    },
    "services-per-server": {
      "path": "/api/servers/{serverId}/services",
      "maxP99Ms": 150,
      "minRps": 200
    },
    "service-deployments-history": {
      "path": "/api/services/{serviceId}/deployments-history",
      "maxP99Ms": 150,
      "minRps": 200
    },
    "dependency-graph": {
      "path": "/api/environments/{envId}/dependency-graph",
      "maxP99Ms": 300,
      "minRps": 100
    },
    "users-list": {
      "path": "/api/users",
      "maxP99Ms": 150,
