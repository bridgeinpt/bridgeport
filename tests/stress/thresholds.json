{
  "$schema": "Latency in ms. Each scenario's p99 must be <= maxP99Ms; non2xx must be 0. Tuned for a fresh laptop / workstation Node runtime, with ~50% headroom above the clean-build p99 so genuine 2x regressions fail. GitHub-hosted runners use the looser thresholds in `thresholds.ci.json` (selected via STRESS_CI=true). Path placeholders {envId,serverId,serviceId,containerImageId,secretId,configFileId} are filled at runtime from seed Refs. We use p99 (not p95) because autocannon's default percentile set tracks p99 but not p95.",
  "scenarios": {
    "auth-me": {
      "path": "/api/auth/me",
      "maxP99Ms": 30,
      "minRps": 3000
    },
    "notifications-unread-count": {
      "path": "/api/notifications/unread-count",
      "maxP99Ms": 30,
      "minRps": 3000
    },
    "environments-list": {
      "path": "/api/environments",
      "maxP99Ms": 30,
      "minRps": 3000
    },
    "environment-detail": {
      "path": "/api/environments/{envId}",
      "maxP99Ms": 30,
      "minRps": 3000
    },
    "servers-list": {
      "path": "/api/environments/{envId}/servers",
      "maxP99Ms": 30,
      "minRps": 1500
    },
    "services-list": {
      "path": "/api/environments/{envId}/services",
      "maxP99Ms": 60,
      "minRps": 800
    },
    "service-detail": {
      "path": "/api/services/{serviceId}",
      "maxP99Ms": 30,
      "minRps": 1500
    },
    "container-images-list": {
      "path": "/api/environments/{envId}/container-images",
      "maxP99Ms": 40,
      "minRps": 1500
    },
    "monitoring-overview": {
      "path": "/api/environments/{envId}/monitoring/overview",
      "maxP99Ms": 30,
      "minRps": 2000
    },
    "agents-status": {
      "path": "/api/environments/{envId}/agents",
      "maxP99Ms": 40,
      "minRps": 1200
    },
    "health-status": {
      "path": "/api/environments/{envId}/health-status",
      "maxP99Ms": 60,
      "minRps": 1000
    },
    "metrics-summary": {
      "path": "/api/environments/{envId}/metrics/summary",
      "maxP99Ms": 120,
      "minRps": 400
    },
    "server-metrics-history": {
      "path": "/api/environments/{envId}/metrics/history?hours=6",
      "maxP99Ms": 60,
      "minRps": 700
    },
    "service-metrics-history": {
      "path": "/api/environments/{envId}/services/metrics/history?hours=6",
      "maxP99Ms": 130,
      "minRps": 350
    },
    "database-metrics-history": {
      "path": "/api/environments/{envId}/databases/metrics/history?hours=6",
      "maxP99Ms": 50,
      "minRps": 1200
    },
    "secrets-list": {
      "path": "/api/environments/{envId}/secrets",
      "maxP99Ms": 100,
      "minRps": 700
    },
    "vars-list": {
      "path": "/api/environments/{envId}/vars",
      "maxP99Ms": 30,
      "minRps": 2000
    },
    "audit-logs": {
      "path": "/api/audit-logs?envId={envId}&limit=50",
      "maxP99Ms": 30,
      "minRps": 1500
    },
    "health-logs": {
      "path": "/api/environments/{envId}/health-logs?limit=50",
      "maxP99Ms": 40,
      "minRps": 1000
    },
    "databases-list": {
      "path": "/api/environments/{envId}/databases",
      "maxP99Ms": 40,
      "minRps": 1200
    },
    "database-monitoring-summary": {
      "path": "/api/environments/{envId}/databases/monitoring-summary",
      "maxP99Ms": 50,
      "minRps": 1000
    },
    "config-files-list": {
      "path": "/api/environments/{envId}/config-files",
      "maxP99Ms": 50,
      "minRps": 800
    },
    "config-fragments-list": {
      "path": "/api/environments/{envId}/config-fragments",
      "maxP99Ms": 30,
      "minRps": 2000
    },
    "services-per-server": {
      "path": "/api/servers/{serverId}/services",
      "maxP99Ms": 30,
      "minRps": 2000
    },
    "service-deployments-history": {
      "path": "/api/services/{serviceId}/deployments-history",
      "maxP99Ms": 30,
      "minRps": 2000
    },
    "dependency-graph": {
      "path": "/api/environments/{envId}/dependency-graph",
      "maxP99Ms": 40,
      "minRps": 1200
    },
    "users-list": {
      "path": "/api/users",
      "maxP99Ms": 30,
      "minRps": 2000
    },
    "notifications-list": {
      "path": "/api/notifications?limit=50",
      "maxP99Ms": 40,
      "minRps": 1200
    }
  },
  "load": {
    "connections": 25,
    "durationSec": 8,
    "pipelining": 1
  }
}
