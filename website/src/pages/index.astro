---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { Card, CardGrid } from '@astrojs/starlight/components';
---

<StarlightPage
  frontmatter={{
    title: 'BridgePort',
    description:
      'Self-hosted Docker deployment, orchestration, and monitoring — production-grade ops without Kubernetes.',
    template: 'splash',
    hero: {
      image: {
        html: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="256" height="256" fill="#cc0000" role="img" aria-label="BridgePort"><rect x="30.5" y="9" width="3" height="20" rx="1.5"/><rect x="20" y="27" width="24" height="2.6" rx="1.3"/><rect x="20" y="38.4" width="24" height="2.6" rx="1.3"/><rect x="21" y="29.6" width="2" height="8.8"/><rect x="25" y="29.6" width="2" height="8.8"/><rect x="29" y="29.6" width="2" height="8.8"/><rect x="33" y="29.6" width="2" height="8.8"/><rect x="37" y="29.6" width="2" height="8.8"/><rect x="41" y="29.6" width="2" height="8.8"/><polygon points="13,16 19,16 13,52 7,52"/><polygon points="45,16 51,16 57,52 51,52"/><rect x="4" y="52" width="14" height="4" rx="1.5"/><rect x="46" y="52" width="14" height="4" rx="1.5"/><rect x="11" y="9" width="42" height="7" rx="2"/><rect x="26" y="16" width="12" height="6" rx="1.5"/></svg>`,
      },
      tagline:
        'Deploy, orchestrate, and monitor Docker services across all your servers. Production-grade ops — without Kubernetes.',
      actions: [
        { text: 'Get started', link: '/getting-started/', icon: 'right-arrow', variant: 'primary' },
        {
          text: 'View on GitHub',
          link: 'https://github.com/bridgeinpt/bridgeport',
          icon: 'external',
          variant: 'minimal',
        },
      ],
    },
  }}
>
  <CardGrid stagger>
    <Card title="Servers & services" icon="puzzle">
      Add servers over SSH or the Docker socket, discover running containers, and deploy services
      from a central image catalog. See [Servers](/guides/servers/) and [Services](/guides/services/).
    </Card>
    <Card title="Config & secrets" icon="seti:lock">
      AES-256-GCM encrypted secrets, reusable config fragments, and templated files synced to your
      servers. See [Secrets](/guides/secrets/) and [Config Files](/guides/config-files/).
    </Card>
    <Card title="Monitoring & health" icon="approve-check">
      Server, service, and database metrics plus container, URL, TCP, and TLS health checks with
      bounce protection. See [Monitoring](/guides/monitoring/) and [Health Checks](/guides/health-checks/).
    </Card>
    <Card title="Orchestration" icon="rocket">
      Multi-service deployment plans with dependency ordering and auto-rollback, plus CI/CD webhooks.
      See [Deployment Plans](/guides/deployment-plans/) and [Webhooks](/guides/webhooks/).
    </Card>
    <Card title="Automate it" icon="setting">
      Drive everything from the REST API, the Go SDK, the CLI, or the Terraform provider.
      See the [API Reference](/reference/api/) and [CLI](/reference/cli/).
    </Card>
    <Card title="Run it in production" icon="open-book">
      Backups, upgrades, security hardening, and real-world topologies. See
      [Operations](/operations/upgrades/) and [Security](/operations/security/).
    </Card>
  </CardGrid>
</StarlightPage>
